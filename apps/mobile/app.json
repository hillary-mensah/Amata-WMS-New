{
  "expo": {
    "name": "NexusOS Mobile POS",
    "slug": "nexusos-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#2563eb"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "bundleIdentifier": "com.amata.nexusos.mobile",
      "supportsTablet": true
    },
    "android": {
      "package": "com.amata.nexusos.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2563eb"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-task-manager"
    ]
  }
}