# Environment Variables
# Copy this file to .env and fill in your values

# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-secure-password
POSTGRES_DB=nexusos_prod

# Redis
REDIS_PASSWORD=change-this-secure-password

# JWT (generate with: openssl rand -hex 64)
JWT_SECRET=your-64-character-secret-here
JWT_REFRESH_SECRET=another-64-character-secret-here

# Paystack (sandbox/test)
PAYSTACK_SECRET_KEY=sk_test_your_key
PAYSTACK_PUBLIC_KEY=pk_test_your_key
PAYSTACK_WEBHOOK_SECRET=whsec_your_webhook_secret

# MTN MoMo
MTN_MOMO_API_KEY=your_api_key
MTN_MOMO_API_SECRET=your_api_secret
MTN_MOMO_COLLECTION_ID=your_collection_id
MTN_MOMO_ENVIRONMENT=sandbox

# Production URLs
API_URL=https://api.nexusos.com
NEXT_PUBLIC_API_URL=https://api.nexusos.com
CORS_ORIGIN=https://app.nexusos.com

# Node
NODE_ENV=production