DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nexusos_dev
REDIS_URL=redis://localhost:6379
JWT_SECRET=<64-char-random-string-here-abc123def456ghi789jkl012mn345op>
JWT_REFRESH_SECRET=<different-64-char-random-string-qrs678tuv901wxy234zab567cde890>
NODE_ENV=development

# API
API_PORT=3001
API_URL=http://localhost:3001

# Web
NEXT_PUBLIC_API_URL=http://localhost:3001

# Paystack (sandbox)
PAYSTACK_SECRET_KEY=sk_test_your_test_key
PAYSTACK_PUBLIC_KEY=pk_test_your_test_key
PAYSTACK_WEBHOOK_SECRET=whsec_your_webhook_secret

# MTN MoMo (sandbox)
MTN_MOMO_API_KEY=your_mtn_api_key
MTN_MOMO_API_SECRET=your_mtn_api_secret
MTN_MOMO_COLLECTION_ID=your_collection_id
MTN_MOMO_ENVIRONMENT=sandbox

# Print
PRINTER_DEFAULT_TYPE=bluetooth
PRINTER_DEFAULT_NAME=Xprinter-N160I

# Sync
SYNC_RETRY_ATTEMPTS=3
SYNC_RETRY_DELAY=5000
SYNC_CONFLICT_RESOLUTION=server

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

#监控
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090