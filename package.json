{
  "name": "amata-nexusos",
  "version": "0.0.1",
  "private": true,
  "description": "Production-grade retail POS and warehouse management system",
  "workspaces": [
    "apps/api",
    "apps/web",
    "apps/mobile",
    "packages/db",
    "packages/auth",
    "packages/cache",
    "packages/sync",
    "packages/payments",
    "packages/printing",
    "packages/queue",
    "packages/types",
    "packages/hardware",
    "packages/ops",
    "packages/governance",
    "packages/intelligence"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:generate": "pnpm --filter @nexus/db generate",
    "db:migrate": "pnpm --filter @nexus/db migrate",
    "db:seed": "pnpm --filter @nexus/db seed",
    "db:studio": "pnpm --filter @nexus/db studio"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "turbo": "^1.13.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=8"
  },
  "packageManager": "pnpm@8.15.0"
}