{
  "root": true,
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "extends": [
    "eslint:recommended"
  ],
  "ignorePatterns": ["node_modules", "dist", ".turbo", ".next"],
  "rules": {
    "no-console": "warn",
    "no-unused-vars": "off"
  }
}